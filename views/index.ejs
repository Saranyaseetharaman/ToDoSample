<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Digital Vault - ToDo</title>
    <link rel="stylesheet" href="/style.css">
    <!-- Google Fonts for Modern Typography -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>
    <div class="app-container">
        <header>
            <h1>Task Vault</h1>
            <p class="subtitle">Manage your daily stack efficiently</p>
        </header>

        <!-- Form context placeholder - replace action/names with your original variables -->
        <form action="/add" method="POST" class="todo-form">
            <input type="text" name="todoItem" placeholder="Add a new task..." required autocomplete="off">
            <button type="submit">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
            </button>
        </form>

        <ul class="todo-list">
            <!-- Dynamic loop elements (Example visual template - keep your original EJS tags here) -->
            <li>
                <span class="task-text">Example Task 1</span>
                <form action="/delete" method="POST" style="display:inline;">
                    <button class="delete-btn">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>
                    </button>
                </form>
            </li>
        </ul>
    </div>
</body>
</html>